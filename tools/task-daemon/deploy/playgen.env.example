# PlayGen Task Daemon — environment configuration
# Copy this file to ~/.playgen.env and fill in real values.
# This file is read by all daemon variants (macOS, Linux, Windows/WSL).

# ── Required ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=-1001234567890
GH_TOKEN=ghp_your_github_token

# ── Optional (defaults shown) ─────────────────────────────────────────────────
GH_REPO=rinehardramos/playgen-project

# Project workspace (absolute path).
# Defaults to the playgen repo root (auto-detected by run-daemon.sh).
# WORKDIR=/path/to/playgen

# State directory for agent logs and registry.
# Defaults to ~/.playgen/state
# PLAYGEN_STATE_DIR=/path/to/state

# Claude CLI flags passed when spawning agents.
# Default enables fully autonomous operation (no permission prompts).
# CLAUDE_FLAGS=--dangerously-skip-permissions

# Claude binary path (auto-discovered from claude-code-vm — rarely needed).
# CLAUDE_BIN=/path/to/claude
