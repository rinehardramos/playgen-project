{
  "name": "playgen",
  "version": "1.09",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "test:unit": "pnpm -r --if-present run test:unit",
    "test:integration": "pnpm -r --if-present run test:integration",
    "test:all": "pnpm run test:unit && pnpm run test:integration",
    "test:e2e:programs": "node e2e/programs-journey.mjs",
    "build": "pnpm -r --if-present run build",
    "lint": "eslint 'services/**/*.ts' 'shared/**/*.ts'",
    "typecheck": "pnpm -r --if-present run build",
    "knowledge:init": "tsx tools/knowledge/src/cli.ts init",
    "knowledge:push": "tsx tools/knowledge/src/cli.ts push",
    "knowledge:search": "tsx tools/knowledge/src/cli.ts search",
    "knowledge:seed": "tsx tools/knowledge/src/cli.ts seed"
  },
  "pnpm": {
    "overrides": {
      "tar": ">=7.5.11",
      "esbuild": ">=0.25.0"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^10.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.2"
  }
}
