# ─── Database ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=playgen
POSTGRES_USER=playgen
POSTGRES_PASSWORD=changeme

# ─── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-this-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_SEC=604800

# ─── Service Ports ──────────────────────────────────────────
AUTH_SERVICE_PORT=3001
STATION_SERVICE_PORT=3002
LIBRARY_SERVICE_PORT=3003
SCHEDULER_SERVICE_PORT=3004
PLAYLIST_SERVICE_PORT=3005
ANALYTICS_SERVICE_PORT=3006

# ─── Internal service URLs (used by gateway / inter-service calls) ──
AUTH_SERVICE_URL=http://auth:3001
STATION_SERVICE_URL=http://station:3002
LIBRARY_SERVICE_URL=http://library:3003
SCHEDULER_SERVICE_URL=http://scheduler:3004
PLAYLIST_SERVICE_URL=http://playlist:3005
ANALYTICS_SERVICE_URL=http://analytics:3006

# ─── Default Admin User (seeded on first migrate run) ───────
ADMIN_EMAIL=admin@playgen.local
ADMIN_PASSWORD=changeme

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
