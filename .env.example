# ────────────────────────────────────────────────────────────────────────────
# LOCAL DOCKER COMPOSE — copy to .env and adjust as needed
# ────────────────────────────────────────────────────────────────────────────

# ─── Database (local Postgres container) ────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=playgen
POSTGRES_USER=playgen
POSTGRES_PASSWORD=changeme

# ─── Database (cloud — Supabase / Railway Postgres / Neon) ──
# Set DATABASE_URL to use a managed database instead of the individual vars above.
# Supabase:  postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Railway:   postgresql://postgres:[password]@[host].railway.internal:5432/railway
# DATABASE_URL=

# ─── Redis (local Redis container) ──────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Redis (cloud — Railway Redis / Upstash) ────────────────
# Set REDIS_URL to use a managed Redis instead of the individual vars above.
# Railway:  redis://default:[password]@[host].railway.internal:6379
# Upstash:  rediss://default:[password]@[host].upstash.io:6379
# REDIS_URL=

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-this-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_SEC=900
JWT_REFRESH_EXPIRES_SEC=604800
# TOKEN_TTL_MINUTES: access token lifetime in minutes (default 15).
# Increase to 60+ in dev/admin environments to avoid mid-workflow expiry
# during long operations (HLS generation ~4 min, audio sourcing ~10 min).
TOKEN_TTL_MINUTES=60

# ─── Service Ports ──────────────────────────────────────────
AUTH_SERVICE_PORT=3001
STATION_SERVICE_PORT=3002
LIBRARY_SERVICE_PORT=3003
SCHEDULER_SERVICE_PORT=3004
PLAYLIST_SERVICE_PORT=3005
ANALYTICS_SERVICE_PORT=3006
DJ_SERVICE_PORT=3007

# ─── AI DJ Service ─────────────────────────────────────────
# LLM backend switch
# 'claude-code' — uses local `claude` CLI subscription (local dev default)
# 'openrouter'  — uses OpenRouter with automatic Gemini Flash fallback (production)
LLM_BACKEND=claude-code

# OpenRouter (LLM) — https://openrouter.ai/keys (used when LLM_BACKEND=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_DEFAULT_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_SITE_URL=https://playgen.site
OPENROUTER_SITE_NAME=PlayGen

# TTS — pluggable: openai | elevenlabs
TTS_PROVIDER=openai
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
TTS_DEFAULT_VOICE=alloy

# Storage — local (dev) | s3 (prod)
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/app/data/audio
S3_BUCKET=
S3_REGION=us-east-1
S3_PREFIX=
S3_ENDPOINT=
S3_PUBLIC_URL_BASE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# OwnRadio integration
# docker-compose local: http://ownradio-api:4000  |  Railway: http://ownradio-api.railway.internal:4000
OWNRADIO_WEBHOOK_URL=
# Shared secret for PlayGen -> OwnRadio webhook calls (X-PlayGen-Secret header)
PLAYGEN_WEBHOOK_SECRET=
# OwnRadio API database (separate DB from PlayGen, same Postgres instance is fine)
OWNRADIO_DATABASE_URL=

# ─── HLS Streaming (DJ service) ────────────────────────────
# Local path inside the DJ container for .ts segments and .m3u8 playlists
HLS_OUTPUT_PATH=/app/data/hls
# Max MB of R2 audio to prefetch before ffmpeg starts (default 500)
HLS_MAX_PREFETCH_MB=500

# ─── Email (Resend) ─────────────────────────────────────────
# Sign up at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_...               # from resend.com
EMAIL_FROM=PlayGen <noreply@playgen.site>

# ─── Google OAuth ────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include GOOGLE_CALLBACK_URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Dev: http://localhost/api/v1/auth/google/callback
# Prod: https://api.playgen.site/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost/api/v1/auth/google/callback
# URL of the frontend (used to redirect after OAuth callback)
# Dev: http://localhost:3000  |  Prod: https://www.playgen.site
FRONTEND_URL=http://localhost:3000

# ─── L2 Knowledge Base (Qdrant + KB API) ───────────────────
# Run tools/knowledge-base/docker-compose.yml to start locally.
QDRANT_URL=http://localhost:6333
KB_API_URL=http://localhost:8000

# ─── Default Admin User (seeded on first migrate run) ───────
ADMIN_EMAIL=admin@playgen.local
ADMIN_PASSWORD=changeme

# ─── Frontend ───────────────────────────────────────────────
# URL of the nginx gateway as seen from the Next.js server process (not the browser)
# Local dev: http://localhost  |  Docker Compose: http://gateway  |  Vercel: https://gateway.up.railway.app
GATEWAY_URL=http://localhost

# Public-facing URL used in browser links (e.g. export buttons).
# Leave blank for same-origin (relative URL). Set to production domain on Vercel.
NEXT_PUBLIC_API_URL=https://api.playgen.site

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ────────────────────────────────────────────────────────────────────────────
# CLOUD DEPLOYMENT ENV VARS (set in Railway / Vercel dashboards, not in .env)
# ────────────────────────────────────────────────────────────────────────────
#
# Railway gateway service:
#   AUTH_HOST=auth.railway.internal
#   STATION_HOST=station.railway.internal
#   LIBRARY_HOST=library.railway.internal
#   SCHEDULER_HOST=scheduler.railway.internal
#   PLAYLIST_HOST=playlist.railway.internal
#   ANALYTICS_HOST=analytics.railway.internal
#   DJ_HOST=dj.railway.internal
#   FRONTEND_HOST=          (leave blank — frontend is on Vercel)
#   DNS_RESOLVER=127.0.0.11
#
# All Railway services (auth, station, library, scheduler, playlist, analytics, dj):
#   DATABASE_URL=<Supabase connection string>
#   REDIS_URL=<Railway Redis or Upstash URL>   (scheduler + dj required)
#   JWT_ACCESS_SECRET=<secret>
#   JWT_REFRESH_SECRET=<secret>
#   NODE_ENV=production
#
# DJ service (Railway — additional env vars):
#   OPENROUTER_API_KEY=<key>
#   OPENAI_API_KEY=<key>              (for TTS)
#   STORAGE_PROVIDER=s3               (or local for dev)
#   S3_BUCKET=<bucket>
#   S3_REGION=<region>
#
# Vercel (frontend):
#   GATEWAY_URL=https://api.playgen.site       ← internal server-side proxy target
#   NEXT_PUBLIC_API_URL=https://www.playgen.site  ← public domain for browser links
#
# ────────────────────────────────────────────────────────────────────────────
# GITHUB ACTIONS SECRETS (set in repo Settings → Secrets → Actions)
# ────────────────────────────────────────────────────────────────────────────
#   RAILWAY_TOKEN         — Railway project deploy token
#   VERCEL_TOKEN          — Vercel personal access token
#   VERCEL_ORG_ID         — from `vercel link` or Vercel dashboard
#   VERCEL_PROJECT_ID     — from `vercel link` or Vercel dashboard
#   SUPABASE_DATABASE_URL — Supabase connection string for migrations
#   OPENROUTER_API_KEY    — OpenRouter LLM key (for DJ service in prod)
#   OPENAI_API_KEY        — OpenAI TTS key (for DJ service in prod)
#
# GITHUB ACTIONS VARIABLES (set in repo Settings → Variables → Actions)
#   PRODUCTION_GATEWAY_URL  = https://api.playgen.site
#   PRODUCTION_FRONTEND_URL = https://www.playgen.site

# ─── Social Media OAuth (DJ service — issues #211 Facebook, #212 Twitter/X) ───
# Required to enable automatic social shoutout ingestion in the AI DJ pipeline.
# Without these, the DJ will only use manually submitted shoutouts.
#
# Generate encryption key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SOCIAL_TOKEN_ENCRYPTION_KEY=<64-char hex string — 32 bytes AES-256-GCM key>
#
# Facebook App (create at https://developers.facebook.com):
#   - Required permissions: pages_read_engagement, pages_read_user_content, pages_show_list
#   - Add Valid OAuth Redirect URI: https://api.playgen.site/api/v1/dj/social/facebook/callback
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
#
# X / Twitter OAuth 2.0 (create at https://developer.twitter.com):
#   - Required scopes: tweet.read users.read offline.access
#   - Add Callback URI: https://api.playgen.site/api/v1/dj/social/twitter/callback
#   - Note: Basic tier ($100/mo) required for @mention search in production
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
#
# Public base URL for OAuth callbacks (DJ service externally accessible URL):
# SOCIAL_CALLBACK_BASE_URL=https://api.playgen.site/api/v1
# FRONTEND_BASE_URL=https://playgen.site

# Feature flags (frontend) — set to "true" to enable, default off
# NEXT_PUBLIC_FEATURE_UI_ADVANCED_PLAYLIST_CREATION=false

# ─── yt-dlp audio sourcing (library service) ───────────────────────────────────
# Optional: path to a Netscape-format cookies.txt file exported from a browser session.
# Required when YouTube blocks server-IP downloads with "Sign in to confirm you're not a bot".
# Mount the file into the container and set this to its container path.
YT_DLP_COOKIES_FILE=
# Optional: override the yt-dlp binary path (default: yt-dlp on PATH)
YT_DLP_PATH=

# ─── info-broker audio sourcing ────────────────────────────────────────────────
# Railway internal: http://info-broker.railway.internal:8000  |  local: http://localhost:8000
INFO_BROKER_URL=http://info-broker.railway.internal:8000
# Shared secret matching INFO_BROKER_API_KEY on the info-broker service
INFO_BROKER_API_KEY=
# PlayGen's own base URL — sent to info-broker as the callback root
PLAYGEN_INTERNAL_URL=https://api.playgen.site

# ─── Local dev: music library mount ────────────────────────────────────────────
# Absolute path to your local music library on the host machine.
# Mounted read-only into the station container at /library (via docker-compose.override.yml).
# Required only for local publish pipeline runs where songs have host filesystem paths.
# Leave empty in production — songs arrive with CDN URLs from the info-broker pipeline.
LOCAL_MUSIC_DIR=
